---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Startseite",
        "item": "https://avorix.cloud/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Personal",
        "item": "https://avorix.cloud/personal"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Arbeitnehmerüberlassung von Köchen",
    "serviceType": "Arbeitnehmerüberlassung",
    "description": "Festangestellte Köche, rechtssicher verliehen: für Notfall, Saison und Übergang. Mit behördlicher Arbeitnehmerüberlassungserlaubnis.",
    "provider": {
      "@type": "Organization",
      "name": "Avorix",
      "url": "https://avorix.cloud/"
    },
    "areaServed": ["DE", "AT"],
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": "#direktantwort"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wer sind die Avorix-Köche?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fest angestellte Profis mit Berufserfahrung in Hotel- und Restaurantküchen."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist, wenn der Koch nicht zu unserem Team passt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dann sprechen Sie mit uns, und wir finden eine Lösung. Es bringt niemandem etwas, wenn die Chemie nicht stimmt."
        }
      },
      {
        "@type": "Question",
        "name": "Wie läuft das vertraglich?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Über einen Arbeitnehmerüberlassungsvertrag, wie ihn die Agentur für Arbeit vorsieht. Sie unterschreiben ein paar Seiten mehr als bei einer Vermittler-Rechnung, und genau das schützt Sie."
        }
      },
      {
        "@type": "Question",
        "name": "Kann aus dem Einsatz mehr werden (Schulung, unser System)?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, jederzeit. Viele Betriebe starten mit einem Personal-Einsatz und bauen danach unser System auf, damit der nächste Ausfall kein Notfall mehr ist."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Köche mieten mit Arbeitnehmerüberlassungserlaubnis | Avorix"
  description="Festangestellte Köche, rechtssicher verliehen: für Notfall, Saison und Übergang. Mit behördlicher Arbeitnehmerüberlassungserlaubnis."
  schemaOrg={schema}
>
  <!-- Hero -->
  <section class="pt-28 pb-16 px-6 bg-gradient-to-b from-brand-50/50 to-white">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-block text-brand-600 text-sm font-semibold tracking-wide uppercase mb-4">
        Modul: Die Verstärkung
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-6 leading-tight">
        Echte Köche. Fest angestellt. Rechtssicher verliehen.
      </h1>
      <div class="flex justify-center mb-6">
        <span class="inline-block bg-brand-50 border border-brand-200 text-brand-700 font-bold rounded-full px-6 py-3 text-base">
          ✓ Behördliche Arbeitnehmerüberlassungserlaubnis · Agentur für Arbeit
        </span>
      </div>
      <p class="text-lg text-neutral-600 leading-relaxed max-w-2xl mx-auto mb-10">
        Wenn Ihnen Personal fehlt, leihen wir Ihnen unsere festangestellten Köche aus: für den Notfall, für die Saison, für den Übergang. Im Gastgewerbe haben diese Erlaubnis nur wenige. Damit sind Sie zu 100 Prozent auf der rechtlich sicheren Seite.
      </p>
      <a
        href="/kontakt"
        data-cta-location="personal-hero"
        class="inline-block bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors"
      >
        Demo vereinbaren
      </a>
    </div>
  </section>

  <!-- Direkt-Antwort (GEO) -->
  <section class="py-8 px-6 bg-white border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <p id="direktantwort" class="text-neutral-700 leading-relaxed">
        Avorix verleiht festangestellte, sozialversicherte Köche an Hotels und Restaurants in Deutschland und Österreich. Grundlage ist die behördliche Arbeitnehmerüberlassungserlaubnis der Agentur für Arbeit. Das schützt Betriebe vor dem Scheinselbständigkeits-Risiko, das bei vermittelten „selbstständigen" Köchen entstehen kann.
      </p>
    </div>
  </section>

  <!-- Wann Sie uns rufen -->
  <section class="py-16 px-6 border-t border-neutral-200">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-12">Wann Sie uns rufen.</h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-2xl border border-neutral-200 p-7">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">Der Notfall.</h3>
          <p class="text-neutral-600 leading-relaxed">
            Der Küchenchef fällt aus, die Saison läuft. Ein Avorix-Koch übernimmt, tageweise oder wochenweise.
          </p>
        </div>
        <div class="bg-white rounded-2xl border border-neutral-200 p-7">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">Die Saison.</h3>
          <p class="text-neutral-600 leading-relaxed">
            Sie brauchen planbar zwei Kräfte mehr. Unsere Köche verstärken Ihr Team für Wochen oder die ganze Saison.
          </p>
        </div>
        <div class="bg-white rounded-2xl border border-neutral-200 p-7">
          <h3 class="text-lg font-semibold text-neutral-900 mb-3">Der Übergang.</h3>
          <p class="text-neutral-600 leading-relaxed">
            Die Neubesetzung dauert länger als geplant. Wir überbrücken, bis Ihre Lösung steht.
          </p>
        </div>
      </div>
      <p class="text-neutral-600 text-center mt-8">
        Kurzfristige Einsätze sind in der Regel innerhalb von 24 bis 72 Stunden möglich, im Notfall sind wir rund um die Uhr erreichbar. 98 Prozent der Anfragen können wir innerhalb von 3 Tagen besetzen.
      </p>
    </div>
  </section>

  <!-- Wissen bleibt -->
  <section class="py-16 px-6 bg-neutral-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">
        Der Leihkoch geht irgendwann wieder. Sein Wissen bleibt da.
      </h2>
      <p class="text-lg text-neutral-600 leading-relaxed">
        Unsere Köche arbeiten mit der Avorix Koch-App und dokumentieren dabei weiter. Sie bezahlen Personal und bauen nebenbei unser System in Ihrer Küche auf. Bei einer klassischen Zeitarbeitsfirma bleibt nach dem Einsatz nichts zurück. Bei uns bleibt das Wissen.
      </p>
    </div>
  </section>

  <!-- Scheinselbständigkeit -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">
        Warum „günstige Selbstständige" Sie 50.000 Euro kosten können.
      </h2>
      <div class="bg-white border-l-4 border-brand-500 rounded-r-2xl p-6 shadow-sm">
        <p class="text-neutral-600 leading-relaxed mb-4">
          Viele Vermittler schicken Ihnen „selbstständige" Köche, die eine Rechnung mit Mehrwertsteuer schreiben. Klingt unkompliziert, ist aber in den meisten Fällen Scheinselbständigkeit: Die Köche arbeiten weisungsgebunden in Ihrem Betriebsablauf, wie Angestellte.
        </p>
        <p class="text-neutral-600 leading-relaxed mb-4">
          Was bei der nächsten Sozialversicherungsprüfung passiert: Die Prüfer stufen diese Köche als scheinselbstständig ein, und zwar in den allermeisten Fällen. Dann zahlt nicht der Koch, sondern Ihr Haus: sämtliche Sozialleistungen, rückwirkend für drei bis vier Jahre. Je nach Umfang schnell 50.000 bis 100.000 Euro. Der Koch selbst ist dann meist nicht mehr greifbar.
        </p>
        <p class="text-neutral-600 leading-relaxed mb-4">
          <strong class="text-neutral-900">Deshalb machen wir es anders:</strong> Unsere Köche sind bei Avorix fest angestellt und sozialversichert. Wir haben die behördliche Arbeitnehmerüberlassungserlaubnis von der Agentur für Arbeit. Unsere Verträge sind von der Agentur für Arbeit geprüft.
        </p>
        <p class="text-neutral-600 leading-relaxed">
          Größere Häuser und Hotelgruppen buchen inzwischen nur noch Firmen mit dieser Erlaubnis, aus genau diesem Grund. Im Gastgewerbe haben sie nur wenige Anbieter. Fragen Sie danach, bevor Sie irgendwo buchen. Auch wenn es nicht bei uns ist.
        </p>
      </div>
    </div>
  </section>

  <!-- Diskretion -->
  <section class="py-16 px-6 bg-neutral-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">
        Ihre Gäste erleben Ihre Küche. Nicht unsere.
      </h2>
      <p class="text-lg text-neutral-600 leading-relaxed">
        Kein Gast merkt, dass ein Avorix-Koch mitkocht. Wir nennen keinen Kunden öffentlich, und auf Wunsch sichern wir Ihnen das vertraglich zu.
      </p>
    </div>
  </section>

  <!-- Was kostet das (Variante B only) -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">Was kostet das?</h2>
      <div class="bg-white rounded-2xl border border-neutral-200 p-7">
        <p class="text-neutral-600 leading-relaxed mb-6">
          Klare Stundensätze, ohne versteckte Posten. Die Zahlen bekommen Sie im Erstgespräch schwarz auf weiß. Für die ersten Betriebe gelten 2026 Pilotkonditionen deutlich unter dem regulären Preis.
        </p>
        <a
          href="/kontakt"
          data-cta-location="personal-kosten"
          class="inline-block bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors"
        >
          Demo vereinbaren
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 bg-neutral-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-10 text-center">Häufige Fragen</h2>
      <div class="space-y-4">
        <details class="border border-neutral-200 rounded-xl p-4 bg-white">
          <summary class="font-semibold text-neutral-900 cursor-pointer">Wer sind die Avorix-Köche?</summary>
          <p class="mt-3 text-neutral-600 leading-relaxed">
            Fest angestellte Profis mit Berufserfahrung in Hotel- und Restaurantküchen.
          </p>
        </details>
        <details class="border border-neutral-200 rounded-xl p-4 bg-white">
          <summary class="font-semibold text-neutral-900 cursor-pointer">Was ist, wenn der Koch nicht zu unserem Team passt?</summary>
          <p class="mt-3 text-neutral-600 leading-relaxed">
            Dann sprechen Sie mit uns, und wir finden eine Lösung. Es bringt niemandem etwas, wenn die Chemie nicht stimmt.
          </p>
        </details>
        <details class="border border-neutral-200 rounded-xl p-4 bg-white">
          <summary class="font-semibold text-neutral-900 cursor-pointer">Wie läuft das vertraglich?</summary>
          <p class="mt-3 text-neutral-600 leading-relaxed">
            Über einen Arbeitnehmerüberlassungsvertrag, wie ihn die Agentur für Arbeit vorsieht. Sie unterschreiben ein paar Seiten mehr als bei einer Vermittler-Rechnung, und genau das schützt Sie.
          </p>
        </details>
        <details class="border border-neutral-200 rounded-xl p-4 bg-white">
          <summary class="font-semibold text-neutral-900 cursor-pointer">Kann aus dem Einsatz mehr werden (Schulung, unser System)?</summary>
          <p class="mt-3 text-neutral-600 leading-relaxed">
            Ja, jederzeit. Viele Betriebe starten mit einem Personal-Einsatz und bauen danach unser System auf, damit der nächste Ausfall kein Notfall mehr ist.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">
        Sagen Sie uns, was Ihrer Küche fehlt.
      </h2>
      <a
        href="/kontakt"
        data-cta-location="personal-final"
        class="inline-block bg-brand-500 text-white px-10 py-4 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors shadow-lg shadow-brand-200"
      >
        Demo vereinbaren
      </a>
    </div>
  </section>
</BaseLayout>
