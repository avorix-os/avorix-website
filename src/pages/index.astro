---
import BaseLayout from "../layouts/BaseLayout.astro";

const schema = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Avorix",
    "url": "https://avorix.cloud",
    "logo": "https://avorix.cloud/avorix-logo.svg",
    "description": "Avorix ermöglicht Hotels und Gastronomiebetrieben, mit Software, standardisierten Prozessen und der Avorix Koch App qualitativ hochwertige Gerichte konsistent anzubieten — auch ohne ausgebildete Köche.",
    "email": "info@avorix.de",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Friedrichshafen",
      "addressCountry": "DE"
    },
    "contactPoint": {
      "@type": "ContactPoint",
      "email": "info@avorix.de",
      "contactType": "sales",
      "availableLanguage": ["German", "English"]
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Avorix",
    "url": "https://avorix.cloud"
  }
];
---

<BaseLayout
  title="Avorix — Ihre Küche hält Ihr Niveau. Auch wenn der Spitzenkoch fehlt."
  description="Avorix führt Ihr Küchenteam Schritt für Schritt durch jedes Gericht. Koch-App, Schulung und Personal aus einer Hand — für konsistente Qualität ohne ausgebildete Köche."
  schemaOrg={schema}
>
  <!-- Hero -->
  <section class="pt-28 pb-16 px-6 bg-gradient-to-b from-brand-50/50 to-white">
    <div class="max-w-4xl mx-auto">
      <p class="text-sm font-bold tracking-widest uppercase text-brand-500 mb-4">Koch-App + Schulung + Personal</p>
      <h1 class="text-4xl md:text-5xl font-extrabold text-neutral-900 leading-tight mb-6">
        Ihre Küche hält Ihr Niveau.<br />Auch wenn der Spitzenkoch fehlt.
      </h1>
      <p class="text-lg text-neutral-600 max-w-3xl leading-relaxed mb-6">
        Avorix führt Ihr Küchenteam Schritt für Schritt durch jedes Gericht Ihrer Karte. Mit klaren Anleitungen, erprobten Abläufen und echten Köchen, die Ihr Team anlernen. Damit jeder Teller so rausgeht, wie Sie es wollen. Jeden Tag. <strong class="text-neutral-900">Auch ohne ausgebildete Köche.</strong>
      </p>
      <div class="flex flex-wrap gap-4 mb-6">
        <a href="/kontakt" data-cta-location="hero" class="bg-brand-500 text-white px-6 py-3 rounded-xl font-bold hover:bg-brand-600 transition-colors">Demo vereinbaren</a>
        <a href="/system" class="border-2 border-brand-500 text-brand-500 px-6 py-3 rounded-xl font-bold hover:bg-brand-50 transition-colors">So funktioniert es</a>
      </div>
      <div class="flex flex-wrap gap-3 text-sm">
        <span class="inline-flex items-center gap-2 bg-neutral-50 border border-brand-200 text-neutral-800 rounded-full px-4 py-2 font-semibold">&#10003; Behördliche Arbeitnehmerüberlassungserlaubnis</span>
        <span class="inline-flex items-center gap-2 bg-neutral-50 border border-brand-200 text-neutral-800 rounded-full px-4 py-2 font-semibold">&#10003; Von Köchen entwickelt</span>
        <span class="inline-flex items-center gap-2 bg-neutral-50 border border-brand-200 text-neutral-800 rounded-full px-4 py-2 font-semibold">&#10003; DE + AT</span>
      </div>
    </div>
  </section>

  <!-- Problem -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">Kommt Ihnen das bekannt vor?</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">Der Küchenchef kündigt. Mitten in der Saison.</h3>
          <p class="text-neutral-600 text-sm">Mit jeder Schlüsselkraft geht Wissen: die Rezepte, die Mengen, die Abläufe. Der Rest des Teams steht da und improvisiert.</p>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">Jeder kocht anders.</h3>
          <p class="text-neutral-600 text-sm">Montag schmeckt das Schnitzel anders als Freitag. Die Portionen schwanken. Stammgäste merken das zuerst.</p>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">Sie finden schlicht niemanden.</h3>
          <p class="text-neutral-600 text-sm">Auf Ihre Stellenanzeige meldet sich niemand, der kochen kann. Und wenn doch, ist er nach einer Saison wieder weg.</p>
        </div>
      </div>
      <p class="text-neutral-600 mt-6">Wenn die Küche wackelt, wackelt alles: erst die Qualität, dann die Bewertungen, dann der Ruf. 82 Prozent der Gastronomiebetriebe melden Fachkräftemangel in der Küche.</p>
    </div>
  </section>

  <!-- Warum Avorix -->
  <section class="py-16 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">Warum Avorix</h2>
      <div class="grid md:grid-cols-3 gap-6 text-left">
        <div class="bg-white border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">&#10003; Konsistente Qualität</h3>
          <p class="text-neutral-600 text-sm">Standardisierte Prozesse und die Avorix Koch App sichern gleichbleibende Speisenqualität, unabhängig vom Erfahrungslevel Ihres Küchenteams.</p>
        </div>
        <div class="bg-white border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">&#128101; Weniger Personalabhängigkeit</h3>
          <p class="text-neutral-600 text-sm">Das Wissen steckt im System, nicht mehr nur in einzelnen Köpfen. Neue Kräfte kochen vom ersten Tag an mit.</p>
        </div>
        <div class="bg-white border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">&#9638; Volle Kostenkontrolle</h3>
          <p class="text-neutral-600 text-sm">Rezeptbasierte Kalkulation, Wareneinsatz-Tracking und standardisierte Portionierung bringen Transparenz in Ihre Küchenkosten.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Erklärung -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-4">Was ist Avorix? In einer Minute erklärt.</h2>
      <p class="text-neutral-600 max-w-3xl mb-8">Stellen Sie sich ein Navi vor. Ein Navi bringt jeden Fahrer ans Ziel, auch wenn er die Strecke nicht kennt. Avorix macht dasselbe in Ihrer Küche: Es bringt jede Küchenkraft zum fertigen Gericht, auch wenn sie es noch nie gekocht hat.</p>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">1 &middot; Ihre Gerichte, glasklar aufgeschrieben.</h3>
          <p class="text-neutral-600 text-sm">Ein erfahrener Avorix-Koch kommt in Ihren Betrieb und schreibt Ihre Karte auf. Jedes Gericht wird in einfache Schritte zerlegt, mit Fotos, genauen Mengen und Zeiten.</p>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">2 &middot; Abläufe, die auch ein kleines Team schafft.</h3>
          <p class="text-neutral-600 text-sm">Vieles wird ruhig vorbereitet, wenn Zeit ist. Im Service wird nur noch fertiggestellt. So stemmt eine kleine Mannschaft eine anspruchsvolle Karte.</p>
        </div>
        <div class="bg-neutral-50 border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">3 &middot; Die Koch-App am Herd.</h3>
          <p class="text-neutral-600 text-sm">Am Posten hängt ein Tablet. Die App zeigt der Küchenkraft Schritt für Schritt, was zu tun ist: Foto, Menge, Zeit, fertig.</p>
        </div>
      </div>
      <div class="mt-8 space-y-3 text-neutral-600">
        <p><strong class="text-neutral-900">Und Ihre Kosten?</strong> Ausgebildete Köche sind teuer, wenn Sie überhaupt welche finden. Mit Avorix kochen angelernte Kräfte auf Ihrem Niveau.</p>
        <p><strong class="text-neutral-900">Und wenn Personal fehlt?</strong> Dann stellen wir es. Avorix beschäftigt festangestellte Köche, die wir Ihnen rechtssicher ausleihen.</p>
        <p><strong class="text-neutral-900">Software, Abläufe und Personal aus einer Hand. Das gibt es so nur bei Avorix.</strong></p>
      </div>
    </div>
  </section>

  <!-- Wo stehen Sie -->
  <section class="py-16 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">Wo stehen Sie gerade?</h2>
      <div class="grid md:grid-cols-3 gap-6">
        <div class="bg-white border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">&bdquo;Der Notfall ist da.&ldquo;</h3>
          <p class="text-neutral-600 text-sm mb-4">Der Koch ist weg, die Saison läuft. Wir schicken Ihnen einen Koch. Und sorgen dafür, dass Sie nie wieder einen suchen müssen.</p>
          <a href="/kontakt" data-cta-location="tuer-notfall" class="text-brand-500 font-bold text-sm hover:text-brand-600">Jetzt Hilfe holen &rarr;</a>
        </div>
        <div class="bg-white border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">&bdquo;Noch läuft es. Aber ich mache mir Sorgen.&ldquo;</h3>
          <p class="text-neutral-600 text-sm mb-4">Alles hängt an einem Kopf. Sichern Sie das Wissen Ihrer Küche, solange es noch im Haus ist.</p>
          <a href="/kontakt" data-cta-location="tuer-sorge" class="text-brand-500 font-bold text-sm hover:text-brand-600">Wissen sichern &rarr;</a>
        </div>
        <div class="bg-white border border-neutral-200 rounded-2xl p-6">
          <h3 class="font-bold text-neutral-900 mb-3">&bdquo;Die Saison kommt.&ldquo;</h3>
          <p class="text-neutral-600 text-sm mb-4">Zu wenig Leute für die Spitze. Saisonkräfte, die ab dem ersten Tag kochen wie Ihr Stammteam.</p>
          <a href="/kontakt" data-cta-location="tuer-saison" class="text-brand-500 font-bold text-sm hover:text-brand-600">Saison planen &rarr;</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Ablauf -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">So kommt Avorix in Ihren Betrieb. In vier Schritten.</h2>
      <div class="space-y-6">
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold shrink-0">1</div>
          <div>
            <h3 class="font-bold text-neutral-900">Wir schauen uns Ihre Küche an. (Kostenlos)</h3>
            <p class="text-neutral-600 text-sm mt-1">Ein Gespräch, 30 Minuten, per Video oder vor Ort. Sie erzählen, wo es klemmt. Wir sagen ehrlich, ob Avorix zu Ihnen passt.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold shrink-0">2</div>
          <div>
            <h3 class="font-bold text-neutral-900">Ein Avorix-Koch nimmt Ihre Karte auf.</h3>
            <p class="text-neutral-600 text-sm mt-1">Er kocht mit Ihrem Team, dokumentiert jedes Gericht, fotografiert jeden Schritt und legt alles in der App an.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold shrink-0">3</div>
          <div>
            <h3 class="font-bold text-neutral-900">Ihr Team lernt das System.</h3>
            <p class="text-neutral-600 text-sm mt-1">Kompakte Schulungstage oder ein Avorix-Koch, der während des Betriebs anlernt. Mit mindestens Sous-Chef-Erfahrung.</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold shrink-0">4</div>
          <div>
            <h3 class="font-bold text-neutral-900">Sie arbeiten selbstständig. Wir bleiben erreichbar.</h3>
            <p class="text-neutral-600 text-sm mt-1">Die App führt Ihr Team durch jeden Tag. Neue Gerichte pflegen Sie selbst ein oder wir übernehmen das.</p>
          </div>
        </div>
      </div>
      <div class="mt-8">
        <a href="/kontakt" data-cta-location="ablauf" class="bg-brand-500 text-white px-6 py-3 rounded-xl font-bold hover:bg-brand-600 transition-colors inline-block">Demo vereinbaren</a>
      </div>
    </div>
  </section>

  <!-- Rechtssicherheit -->
  <section class="py-16 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">Und wenn Personal fehlt: Wir leihen Ihnen unsere Köche. Rechtssicher.</h2>
      <div class="bg-white border-l-4 border-brand-500 rounded-r-2xl p-6">
        <p class="text-neutral-600 mb-4">Viele Vermittler schicken Ihnen &bdquo;selbstständige&ldquo; Köche mit Rechnung. Das Problem: Bei einer Prüfung stuft die Rentenversicherung diese Köche oft als scheinselbstständig ein. Nachforderungen schnell im hohen fünfstelligen Bereich.</p>
        <p class="text-neutral-600 mb-4">Bei Avorix passiert Ihnen das nicht. Unsere Köche sind bei uns fest angestellt und sozialversichert. Wir haben die behördliche Arbeitnehmerüberlassungserlaubnis.</p>
        <p class="text-neutral-900 font-semibold">Im Gastgewerbe haben nur wenige Anbieter diese Erlaubnis. Fragen Sie danach, bevor Sie irgendwo buchen.</p>
      </div>
      <div class="mt-6">
        <a href="/personal" data-cta-location="rechtssicherheit" class="border-2 border-brand-500 text-brand-500 px-6 py-3 rounded-xl font-bold hover:bg-brand-50 transition-colors inline-block">Mehr zu Schulung und Personal</a>
      </div>
    </div>
  </section>

  <!-- Gründer -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">Von einem Küchenchef gebaut. Nicht von Software-Leuten.</h2>
      <div class="grid md:grid-cols-[150px_1fr] gap-6">
        <div class="w-full h-44 md:h-auto rounded-2xl bg-neutral-100 border-2 border-dashed border-neutral-300 flex items-center justify-center text-neutral-400 text-sm text-center p-4">
          Foto Börge Penk
        </div>
        <div>
          <p class="text-neutral-600 mb-4">Börge Penk hat 20 Jahre in Profiküchen gearbeitet, als Küchenchef auch mit großen Teams. Den Fachkräftemangel kennt er nicht aus Statistiken, sondern aus jedem einzelnen Dienstplan.</p>
          <blockquote class="bg-neutral-50 rounded-xl p-4 italic text-neutral-800 mb-4">&bdquo;Ich habe zu oft erlebt, dass eine Küche steht und fällt mit einer einzigen Person. Das muss nicht sein. Gutes Kochen kann man aufschreiben, zeigen und beibringen.&ldquo;</blockquote>
          <p class="text-neutral-600 text-sm">Sie finden auf dieser Seite keine Kundenlogos. Das ist Absicht. Unsere Kunden führen ihre Küche mit unserem System, und was in ihrer Küche passiert, geht niemanden etwas an.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Kosten -->
  <section class="py-16 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">Was kostet das?</h2>
      <div class="bg-white border border-neutral-200 rounded-2xl p-6">
        <p class="text-neutral-600 mb-4">Das hängt von Ihrer Karte und Ihrem Team ab. Im Erstgespräch rechnen wir es Ihnen transparent vor, auf den Euro genau und ohne Kleingedrucktes. Für die ersten Betriebe gibt es 2026 Pilotkonditionen deutlich unter dem regulären Preis.</p>
      </div>
      <div class="mt-6 flex flex-wrap gap-4">
        <a href="/kontakt" data-cta-location="kosten" class="bg-brand-500 text-white px-6 py-3 rounded-xl font-bold hover:bg-brand-600 transition-colors">Demo vereinbaren</a>
        <a href="/pilotprogramm" data-cta-location="kosten-pilot" class="border-2 border-brand-500 text-brand-500 px-6 py-3 rounded-xl font-bold hover:bg-brand-50 transition-colors">Zum Pilotprogramm</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">Häufige Fragen</h2>
      <div class="space-y-3">
        <details open class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Wer tippt unsere Rezepte ein?</summary>
          <p class="text-neutral-600 text-sm mt-3">Wir. Ein Avorix-Koch kommt zu Ihnen, kocht mit Ihrem Team und legt jedes Gericht in der App an. Sie müssen nichts selbst einpflegen.</p>
        </details>
        <details class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Merken unsere Gäste etwas davon?</summary>
          <p class="text-neutral-600 text-sm mt-3">Nein. Ihre Gäste erleben Ihre Küche und Ihre Rezepte, nur eben verlässlich in gleicher Qualität. Auf Wunsch sichern wir Ihnen vertraglich zu, dass wir Ihren Betrieb nirgends als Referenz nennen.</p>
        </details>
        <details class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Unser Team ist nicht besonders technikaffin. Klappt das trotzdem?</summary>
          <p class="text-neutral-600 text-sm mt-3">Ja, dafür ist die App gebaut. Wer ein Foto ansehen und einen Haken setzen kann, kann mit ihr arbeiten. Geschult wird direkt am Herd.</p>
        </details>
        <details class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Was passiert mit unseren Rezepten? Wem gehören die?</summary>
          <p class="text-neutral-600 text-sm mt-3">Ihnen. Ihre Rezepte bleiben Ihr Eigentum und werden nicht an andere Betriebe weitergegeben.</p>
        </details>
        <details class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Wie schnell sind wir startklar?</summary>
          <p class="text-neutral-600 text-sm mt-3">Vom Erstgespräch bis zum eigenständigen Arbeiten vergehen je nach Karte typischerweise wenige Wochen.</p>
        </details>
        <details class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Welche Technik brauchen wir in der Küche?</summary>
          <p class="text-neutral-600 text-sm mt-3">Ein Tablet oder Smartphone und eine Internetverbindung. Die App läuft im Browser, es muss nichts installiert werden.</p>
        </details>
        <details class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Ersetzt das unseren Küchenchef?</summary>
          <p class="text-neutral-600 text-sm mt-3">Nein. Ein guter Küchenchef wird mit Avorix besser, weil sein Wissen endlich festgehalten ist und sein Team selbstständiger arbeitet.</p>
        </details>
        <details class="bg-neutral-50 border border-neutral-200 rounded-xl p-4">
          <summary class="font-bold text-neutral-900 cursor-pointer">Wir sind in Österreich. Geht das?</summary>
          <p class="text-neutral-600 text-sm mt-3">Ja, wir arbeiten in Deutschland und Österreich.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-neutral-900 mb-4">Der nächste Schritt ist ein Gespräch. Mehr nicht.</h2>
      <p class="text-neutral-600 mb-6">30 Minuten, kostenlos, unverbindlich. Sie erzählen uns von Ihrer Küche, wir sagen Ihnen ehrlich, ob Avorix zu Ihnen passt und was es kosten würde.</p>
      <a href="/kontakt" data-cta-location="final" class="bg-brand-500 text-white px-8 py-4 rounded-xl font-bold text-lg hover:bg-brand-600 transition-colors inline-block">Demo vereinbaren</a>
      <p class="text-neutral-400 text-sm mt-4">Noch nicht so weit? <a href="/leitfaden" class="text-brand-500 hover:underline">Holen Sie sich unseren kostenlosen Leitfaden.</a></p>
    </div>
  </section>
</BaseLayout>
