---
import BaseLayout from "../layouts/BaseLayout.astro";

const schemaOrg = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      {
        "@type": "ListItem",
        "position": 1,
        "name": "Avorix",
        "item": "https://avorix.cloud/"
      },
      {
        "@type": "ListItem",
        "position": 2,
        "name": "Die Schulung",
        "item": "https://avorix.cloud/schulung"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Küchen-Schulung durch Avorix-Köche",
    "description": "Ein Avorix-Koch mit Sous-Chef-Erfahrung nimmt Ihre Karte auf und lernt Ihr Team an, direkt am Herd. Als Schulungsblock oder live im Betrieb.",
    "provider": {
      "@type": "Organization",
      "name": "Avorix GmbH",
      "url": "https://avorix.cloud",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Friedrichshafen",
        "addressCountry": "DE"
      },
      "founder": {
        "@type": "Person",
        "name": "Avorix"
      },
      "areaServed": {
        "@type": "Country",
        "name": "DE"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Wer sind die Avorix-Köche?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Fest angestellte Profis mit Berufserfahrung in Hotel- und Restaurantküchen. Wer bei uns schult, hat mindestens Sous-Chef-Erfahrung."
        }
      },
      {
        "@type": "Question",
        "name": "Was ist, wenn der Koch nicht zu unserem Team passt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dann sprechen Sie mit uns, und wir finden eine Lösung. Es bringt niemandem etwas, wenn die Chemie nicht stimmt."
        }
      },
      {
        "@type": "Question",
        "name": "Wie schnell ist mein Team fit?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Wer eine Woche mit der App gekocht hat, braucht sie nicht mehr erklärt zu bekommen. Für eine typische Karte rechnen Sie mit zwei Blöcken."
        }
      },
      {
        "@type": "Question",
        "name": "Arbeiten die Köche mit der Koch-App?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Dadurch hinterlässt jeder Einsatz dokumentiertes Wissen in Ihrer Küche."
        }
      }
    ]
  }
];
---

<BaseLayout
  title="Küchen-Schulung durch erfahrene Köche | Avorix"
  description="Ein Avorix-Koch mit Sous-Chef-Erfahrung nimmt Ihre Karte auf und lernt Ihr Team an, direkt am Herd. Als Schulungsblock oder live im Betrieb."
  schemaOrg={schemaOrg}
>

  <!-- Hero -->
  <section class="pt-28 pb-16 px-6 bg-gradient-to-b from-brand-50/50 to-white">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 bg-brand-100 text-brand-700 text-xs font-semibold px-3 py-1 rounded-full mb-6">
        Modul: Die Schulung
      </span>
      <h1 class="text-4xl md:text-6xl font-bold text-neutral-900 mb-6 leading-tight">
        Ihr Team lernt unser System. Von Köchen, die es selbst können.
      </h1>
      <p class="text-xl text-neutral-600 leading-relaxed max-w-2xl mx-auto mb-10">
        Ein Avorix-Koch mit mindestens Sous-Chef-Erfahrung nimmt Ihre Karte auf, legt sie in der Koch-App an und lernt Ihr Team an, direkt am Herd, nicht im Seminarraum.
      </p>
      <a
        href="/kontakt"
        data-cta-location="schulung-hero"
        class="inline-block bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors"
      >
        Demo vereinbaren
      </a>
      <p class="text-sm text-neutral-600 mt-6 inline-flex items-center gap-2 bg-neutral-100 px-4 py-2 rounded-full">
        ✓ Behördliche Arbeitnehmerüberlassungserlaubnis (Agentur für Arbeit)
      </p>
    </div>
  </section>

  <!-- Zwei Wege -->
  <section class="py-16 px-6 border-t border-neutral-200">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-12">
        Anlernen, wie es zu Ihrem Betrieb passt.
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <!-- Weg 1 -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-200 hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <span class="text-brand-600 font-bold text-sm">1</span>
          </div>
          <h3 class="text-xl font-semibold text-neutral-900 mb-3">Weg 1: Die Block-Schulung</h3>
          <p class="text-neutral-600 leading-relaxed">
            Ein Avorix-Koch kommt für einen Block zu Ihnen: fünf Tage mit je sechs Stunden. Er konzentriert sich ganz auf Ihre Küche, nimmt die Karte auf, dokumentiert, fotografiert und lernt Ihr Team an. Er kocht in dieser Zeit nicht im Service mit, seine ganze Aufmerksamkeit gehört dem Anlernen. Für eine typische Karte rechnen Sie mit zwei Blöcken: erst Aufnahme und Dokumentation, dann die reine Schulung mit dem fertigen Material.
          </p>
        </div>
        <!-- Weg 2 -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-200 hover:border-brand-200 hover:shadow-md transition-all">
          <div class="w-10 h-10 bg-brand-100 rounded-lg flex items-center justify-center mb-4">
            <span class="text-brand-600 font-bold text-sm">2</span>
          </div>
          <h3 class="text-xl font-semibold text-neutral-900 mb-3">Weg 2: Die Live-Schulung</h3>
          <p class="text-neutral-600 leading-relaxed">
            Ein Avorix-Koch arbeitet ganz normal in Ihrer Küche mit, macht Bons fertig und produziert, und lernt Ihr Team nebenbei an, mitten im echten Betrieb. Sie bezahlen einen produktiven Koch und bekommen die Schulung dazu.
          </p>
        </div>
      </div>
      <p class="text-sm text-neutral-600 text-center mt-8 bg-brand-50 rounded-xl px-6 py-3">
        <strong>Für beide Wege gilt:</strong> Der Avorix-Koch hat mindestens Sous-Chef-Erfahrung. Es schult niemand, der es nicht selbst jeden Tag kann.
      </p>
    </div>
  </section>

  <!-- Am Herd -->
  <section class="py-16 px-6 bg-neutral-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">
        Am Herd. Im echten Betrieb. Mit Ihrem eigenen Essen.
      </h2>
      <p class="text-lg text-neutral-600 leading-relaxed mb-6">
        Geschult wird nicht mit Beispielrezepten, sondern mit Ihrer Karte. Ihr Team lernt genau die Gerichte, die es ab morgen kocht, mit der App, die ab morgen am Posten hängt. Wer eine Woche so gearbeitet hat, braucht keine Erklärung mehr.
      </p>
      <p class="text-neutral-600 leading-relaxed mb-8">
        <strong>Und wenn während der Schulung Personal fehlt:</strong> Dafür gibt es unser Personal-Modul, festangestellte Köche, rechtssicher verliehen.
      </p>
      <a
        href="/personal"
        data-cta-location="schulung-personal-link"
        class="inline-flex items-center gap-2 text-brand-500 font-semibold hover:text-brand-600 transition-colors"
      >
        Zum Personal-Modul
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    </div>
  </section>

  <!-- Was kostet das -->
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-8">Was kostet das?</h2>
      <div class="bg-white rounded-2xl p-8 border border-neutral-200">
        <p class="text-lg text-neutral-600 leading-relaxed mb-6">
          Klare Stundensätze und Blockpreise, ohne versteckte Posten. Die Zahlen bekommen Sie im Erstgespräch schwarz auf weiß. Für die ersten Betriebe gelten 2026 Pilotkonditionen deutlich unter dem regulären Preis.
        </p>
        <a
          href="/kontakt"
          data-cta-location="schulung-kosten"
          class="inline-block bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors"
        >
          Demo vereinbaren
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 bg-neutral-50">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 mb-10 text-center">Häufige Fragen</h2>
      <div class="space-y-4">
        <details class="border border-neutral-200 rounded-xl p-4 bg-white group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Wer sind die Avorix-Köche?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">
            Fest angestellte Profis mit Berufserfahrung in Hotel- und Restaurantküchen. Wer bei uns schult, hat mindestens Sous-Chef-Erfahrung.
          </p>
        </details>

        <details class="border border-neutral-200 rounded-xl p-4 bg-white group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Was ist, wenn der Koch nicht zu unserem Team passt?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">
            Dann sprechen Sie mit uns, und wir finden eine Lösung. Es bringt niemandem etwas, wenn die Chemie nicht stimmt.
          </p>
        </details>

        <details class="border border-neutral-200 rounded-xl p-4 bg-white group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Wie schnell ist mein Team fit?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">
            Wer eine Woche mit der App gekocht hat, braucht sie nicht mehr erklärt zu bekommen. Für eine typische Karte rechnen Sie mit zwei Blöcken.
          </p>
        </details>

        <details class="border border-neutral-200 rounded-xl p-4 bg-white group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Arbeiten die Köche mit der Koch-App?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">
            Ja. Dadurch hinterlässt jeder Einsatz dokumentiertes Wissen in Ihrer Küche.
          </p>
        </details>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-20 px-6">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">
        Sagen Sie uns, was Ihrer Küche fehlt.
      </h2>
      <a
        href="/kontakt"
        data-cta-location="schulung-final"
        class="inline-block bg-brand-500 text-white px-10 py-4 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors shadow-lg shadow-brand-200"
      >
        Demo vereinbaren
      </a>
    </div>
  </section>
</BaseLayout>
