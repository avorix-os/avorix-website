---
import BaseLayout from "../layouts/BaseLayout.astro";

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Startseite",
      "item": "https://avorix.cloud/"
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Pilotprogramm",
      "item": "https://avorix.cloud/pilotprogramm"
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Was kostet mich das Pilotprogramm?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Deutlich weniger als der reguläre Preis. Die genaue Zahl hängt von Ihrer Karte ab und steht nach der Küchen-Analyse fest, schriftlich und ohne versteckte Posten."
      }
    },
    {
      "@type": "Question",
      "name": "Wie lange bin ich gebunden?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Die App-Nutzung läuft über 12 Monate. Kürzer ist nicht seriös: Ein System, das Ihre Küche verändert, beweist sich nicht in vier Wochen."
      }
    },
    {
      "@type": "Question",
      "name": "Muss ich als Referenz auftreten?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Nein. Anonyme Auswertung ja, öffentliche Referenz nur, wenn Sie das ausdrücklich wollen. Dann mit eigenem Deal."
      }
    },
    {
      "@type": "Question",
      "name": "Was ist, wenn es bei uns nicht funktioniert?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Dann sagen wir uns das offen, im Zweifel auch: Abbruch. Genau dafür sind Pilotprojekte da. Ihre Rezeptdokumentation behalten Sie in jedem Fall, die Arbeit war dann nicht umsonst."
      }
    },
    {
      "@type": "Question",
      "name": "Wir haben gar keinen Küchenchef mehr. Geht es trotzdem?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Gerade dann. Für die Übergangszeit können wir zusätzlich einen unserer festangestellten Köche rechtssicher ausleihen. Sprechen Sie es im Kennenlern-Gespräch an."
      }
    }
  ]
};
---

<BaseLayout
  title="Pilotprogramm 2026 für Hotel- und Restaurantküchen | Avorix"
  description="Werden Sie Pilotbetrieb: das komplette Avorix-System zu Pilotkonditionen, gegen ehrliches Feedback und anonyme Auswertung."
  schemaOrg={[breadcrumbSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="pt-28 pb-16 px-6 bg-gradient-to-b from-brand-50/50 to-white">
    <div class="max-w-4xl mx-auto text-center">
      <span class="inline-flex items-center gap-2 bg-brand-100 text-brand-700 text-xs font-semibold px-3 py-1 rounded-full mb-6">
        <span class="w-2 h-2 rounded-full bg-brand-500 animate-pulse"></span>
        Pilotprogramm 2026
      </span>
      <h1 class="text-4xl md:text-5xl font-bold text-neutral-900 mb-6 leading-tight">
        Wir suchen 3 Hotelküchen, die 2026 mit uns den Beweis antreten.
      </h1>
      <p class="text-xl text-neutral-600 leading-relaxed max-w-3xl mx-auto mb-10">
        Die Avorix Koch-App ist neu. Was nicht neu ist: unsere Köche und unsere Abläufe, die seit Jahren in Profiküchen stehen. Was uns noch fehlt, sind Betriebe, deren Ergebnisse wir zeigen dürfen. Deshalb machen wir Ihnen ein Angebot, das wir so nur den ersten Häusern machen.
      </p>
      <a
        href="#anfrage"
        data-cta-location="hero"
        class="inline-block bg-brand-500 text-white px-8 py-3 rounded-lg font-semibold text-base hover:bg-brand-600 transition-colors shadow-lg shadow-brand-200"
      >
        Pilotplatz anfragen
      </a>
    </div>
  </section>

  <!-- Das Angebot -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-12">Das Angebot. Ohne Kleingedrucktes.</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Sie bekommen -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm">
          <h3 class="text-lg font-semibold text-neutral-900 mb-4">Sie bekommen:</h3>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Das komplette Avorix-System: Rezeptaufnahme durch einen erfahrenen Koch, Schulung Ihres Teams direkt am Herd, die Koch-App für Ihren ganzen Betrieb.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong>Pilotkonditionen: rund die Hälfte des regulären Preises.</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Den direkten Draht zum Gründer: Börge Penk betreut die Pilotbetriebe persönlich.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Priorität bei allem: Ihre Wünsche fließen zuerst in die App ein.</span>
            </li>
          </ul>
        </div>
        <!-- Wir bekommen -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-100 shadow-sm">
          <h3 class="text-lg font-semibold text-neutral-900 mb-4">Wir bekommen:</h3>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Ihr ehrliches Feedback. Auch das unbequeme.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Die Erlaubnis, Ihre Ergebnisse anonym auszuwerten (zum Beispiel: „Ein Ferienhotel am Bodensee senkte den Wareneinsatz um X Prozent"). Ihr Name taucht dabei nirgends auf, das sichern wir vertraglich zu.</span>
            </li>
          </ul>
        </div>
      </div>
      <p class="text-neutral-500 text-center mt-8 max-w-2xl mx-auto">
        Wenn Sie darüber hinaus bereit sind, öffentlich als Referenz aufzutreten, sprechen wir über einen eigenen Deal mit noch besseren Konditionen. Das ist aber freiwillig und keine Bedingung.
      </p>
    </div>
  </section>

  <!-- Passt das -->
  <section class="py-16 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-5xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-12">Passt das zu Ihrem Haus?</h2>
      <div class="grid md:grid-cols-2 gap-8">
        <!-- Passt -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-100">
          <h3 class="text-lg font-semibold text-brand-600 mb-4">Das Pilotprogramm passt, wenn:</h3>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Sie ein Hotel oder Restaurant in Deutschland oder Österreich führen, idealerweise mit Halbpension oder fester Karte.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Der Fachkräftemangel bei Ihnen real ist: offene Stellen, Abhängigkeit von einzelnen Köpfen, schwankende Qualität.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-brand-500 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span>Sie bereit sind, Abläufe zu verändern. Nicht alles auf einmal, aber ernsthaft.</span>
            </li>
          </ul>
        </div>
        <!-- Passt nicht -->
        <div class="bg-white rounded-2xl p-8 border border-neutral-100">
          <h3 class="text-lg font-semibold text-neutral-900 mb-4">Es passt nicht, wenn:</h3>
          <ul class="space-y-3 text-neutral-600">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-neutral-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span>Sie eine täglich wechselnde Spitzengastronomie mit eigenem Patron am Herd führen. Dafür ist Avorix nicht gebaut.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-neutral-400 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <span>Sie nur die App wollen, aber nichts am Ablauf ändern möchten. Dann verbrennen wir beide Zeit und Geld.</span>
            </li>
          </ul>
        </div>
      </div>
      <p class="text-neutral-500 text-center mt-8 max-w-2xl mx-auto">
        Diese Ehrlichkeit sparen wir uns nicht. Ein Pilotprojekt, das nicht passt, schadet Ihnen und uns.
      </p>
    </div>
  </section>

  <!-- Vier Schritte -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-12">Vier Schritte bis zur Küche, die immer funktioniert.</h2>
      <div class="space-y-8">
        <!-- Schritt 1 -->
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold text-lg shrink-0">1</div>
          <div>
            <h3 class="text-lg font-semibold text-neutral-900 mb-1">Kennenlern-Gespräch (30 Minuten, kostenlos).</h3>
            <p class="text-neutral-600">Per Video oder Telefon. Sie schildern Ihre Situation, wir prüfen gemeinsam, ob das Pilotprogramm passt. Danach entscheiden beide Seiten in Ruhe.</p>
          </div>
        </div>
        <!-- Schritt 2 -->
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold text-lg shrink-0">2</div>
          <div>
            <h3 class="text-lg font-semibold text-neutral-900 mb-1">Küchen-Analyse vor Ort.</h3>
            <p class="text-neutral-600">Ein Avorix-Koch schaut sich Ihre Küche, Ihre Karte und Ihr Team an. Sie bekommen einen konkreten Fahrplan mit Aufwand und Kosten, auf den Euro genau.</p>
          </div>
        </div>
        <!-- Schritt 3 -->
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold text-lg shrink-0">3</div>
          <div>
            <h3 class="text-lg font-semibold text-neutral-900 mb-1">Aufnahme und Schulung.</h3>
            <p class="text-neutral-600">Wir dokumentieren Ihre Karte, richten die App ein und schulen Ihr Team am Herd, während der Betrieb normal weiterläuft.</p>
          </div>
        </div>
        <!-- Schritt 4 -->
        <div class="flex gap-4 items-start">
          <div class="w-10 h-10 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold text-lg shrink-0">4</div>
          <div>
            <h3 class="text-lg font-semibold text-neutral-900 mb-1">Laufender Betrieb mit Begleitung.</h3>
            <p class="text-neutral-600">Ihr Team arbeitet mit dem System. Wir bleiben dran, sammeln Ihr Feedback und justieren nach. Alle paar Wochen ein kurzes Gespräch mit Börge.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gründer -->
  <section class="py-16 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-12">Wer hinter dem Angebot steht</h2>
      <div class="grid md:grid-cols-3 gap-8 items-start">
        <div class="flex justify-center">
          <div class="w-48 h-48 rounded-2xl bg-neutral-200 flex items-center justify-center text-neutral-400">
            <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
          </div>
        </div>
        <div class="md:col-span-2">
          <p class="text-neutral-600 leading-relaxed mb-6">
            Börge Penk, Küchenchef mit 20 Jahren Praxis, hat Avorix aus dem eigenen Küchenalltag heraus entwickelt. Für die Pilotbetriebe ist er persönlich verantwortlich:
          </p>
          <blockquote class="border-l-4 border-brand-500 pl-6 italic text-neutral-600">
            „Bei den ersten Häusern stehe ich selbst gerade. Wenn es dort nicht funktioniert, funktioniert unser Geschäftsmodell nicht. Einfacher kann ich Ihr Risiko nicht machen."
          </blockquote>
        </div>
      </div>
    </div>
  </section>

  <!-- Warum 3 -->
  <section class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl font-bold text-neutral-900 mb-6">Warum nur 3 Plätze?</h2>
      <p class="text-neutral-600 leading-relaxed max-w-2xl mx-auto">
        Weil jede Einführung echte Menschen braucht: Ein Avorix-Koch steht bei Ihnen in der Küche, nicht in einem Callcenter. Mehr als einen neuen Betrieb pro Monat können wir sauber betreuen, und Qualität geht vor Wachstum. Deshalb ist bei 3 Pilotbetrieben Schluss. Danach gelten reguläre Konditionen.
      </p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-16 px-6 bg-neutral-50 border-t border-neutral-100">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-12">Häufige Fragen</h2>
      <div class="space-y-4">
        <details open class="bg-white border border-neutral-200 rounded-xl p-4 group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Was kostet mich das Pilotprogramm?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">Deutlich weniger als der reguläre Preis. Die genaue Zahl hängt von Ihrer Karte ab und steht nach der Küchen-Analyse fest, schriftlich und ohne versteckte Posten.</p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-4 group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Wie lange bin ich gebunden?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">Die App-Nutzung läuft über 12 Monate. Kürzer ist nicht seriös: Ein System, das Ihre Küche verändert, beweist sich nicht in vier Wochen.</p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-4 group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Muss ich als Referenz auftreten?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">Nein. Anonyme Auswertung ja, öffentliche Referenz nur, wenn Sie das ausdrücklich wollen. Dann mit eigenem Deal.</p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-4 group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Was ist, wenn es bei uns nicht funktioniert?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">Dann sagen wir uns das offen, im Zweifel auch: Abbruch. Genau dafür sind Pilotprojekte da. Ihre Rezeptdokumentation behalten Sie in jedem Fall, die Arbeit war dann nicht umsonst.</p>
        </details>
        <details class="bg-white border border-neutral-200 rounded-xl p-4 group">
          <summary class="font-semibold text-neutral-900 cursor-pointer list-none flex items-center justify-between">
            Wir haben gar keinen Küchenchef mehr. Geht es trotzdem?
            <svg class="w-5 h-5 text-neutral-400 group-open:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <p class="text-neutral-600 mt-3 leading-relaxed">Gerade dann. Für die Übergangszeit können wir zusätzlich einen unserer festangestellten Köche rechtssicher ausleihen. Sprechen Sie es im Kennenlern-Gespräch an.</p>
        </details>
      </div>
    </div>
  </section>

  <!-- Pilotplatz anfragen -->
  <section id="anfrage" class="py-16 px-6 border-t border-neutral-100">
    <div class="max-w-2xl mx-auto">
      <h2 class="text-3xl font-bold text-neutral-900 text-center mb-4">Pilotplatz anfragen. Unverbindlich.</h2>
      <p class="text-neutral-600 text-lg text-center mb-10">Drei Minuten. Danach melden wir uns innerhalb von zwei Werktagen.</p>

      <form id="pilot-form" class="space-y-5 bg-white rounded-2xl border border-neutral-100 shadow-sm p-8" action="https://formspree.io/f/xqegwngo" method="POST">
        <input type="hidden" name="_subject" value="Pilot-Anfrage über avorix.cloud" />

        <div>
          <label for="pilot-name" class="block text-sm font-medium text-avorix-dark mb-1">
            Name <span class="text-brand-500">*</span>
          </label>
          <input
            type="text"
            id="pilot-name"
            name="name"
            required
            class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark"
          />
        </div>

        <div>
          <label for="pilot-betrieb" class="block text-sm font-medium text-avorix-dark mb-1">
            Betrieb (Hotel/Restaurant) + Ort <span class="text-brand-500">*</span>
          </label>
          <input
            type="text"
            id="pilot-betrieb"
            name="betrieb"
            required
            class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark"
          />
        </div>

        <div>
          <label for="pilot-email" class="block text-sm font-medium text-avorix-dark mb-1">
            E-Mail <span class="text-brand-500">*</span>
          </label>
          <input
            type="email"
            id="pilot-email"
            name="email"
            required
            class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark"
          />
        </div>

        <div>
          <label for="pilot-telefon" class="block text-sm font-medium text-avorix-dark mb-1">
            Telefon <span class="text-neutral-400 font-normal">(optional, für schnellere Rückmeldung)</span>
          </label>
          <input
            type="tel"
            id="pilot-telefon"
            name="telefon"
            class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark"
          />
        </div>

        <div>
          <label for="pilot-teamgroesse" class="block text-sm font-medium text-avorix-dark mb-1">
            Wie groß ist Ihr Küchenteam?
          </label>
          <select
            id="pilot-teamgroesse"
            name="kuechenteam"
            class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark bg-white"
          >
            <option value="">Bitte wählen</option>
            <option value="1 bis 3">1 bis 3</option>
            <option value="4 bis 8">4 bis 8</option>
            <option value="mehr als 8">mehr als 8</option>
          </select>
        </div>

        <div>
          <label for="pilot-problem" class="block text-sm font-medium text-avorix-dark mb-1">
            Was ist gerade Ihr größtes Küchenproblem? <span class="text-neutral-400 font-normal">(optional)</span>
          </label>
          <textarea
            id="pilot-problem"
            name="kuechenproblem"
            rows="4"
            class="w-full px-4 py-2 border border-avorix-light rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-avorix-dark/20 focus:border-avorix-dark resize-none"
          ></textarea>
        </div>

        <div id="pilot-success" class="hidden bg-brand-50 border border-brand-100 rounded-lg px-4 py-3 text-brand-700 text-sm font-medium">
          Danke. Wir melden uns innerhalb von zwei Werktagen.
        </div>

        <button
          type="submit"
          data-cta-location="final"
          class="bg-brand-500 text-white px-8 py-3 rounded-lg text-sm font-semibold hover:bg-brand-600 active:bg-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2 transition-colors w-full"
        >
          Pilotplatz anfragen
        </button>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  const pilotForm = document.getElementById('pilot-form') as HTMLFormElement;
  if (pilotForm) {
    let pilotSent = false;
    pilotForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      const submitBtn = pilotForm.querySelector('[type="submit"]') as HTMLButtonElement;
      const successMsg = document.getElementById('pilot-success');
      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.textContent = 'Wird gesendet\u2026';
      }
      try {
        const response = await fetch(pilotForm.action, {
          method: 'POST',
          body: new FormData(pilotForm),
          headers: { 'Accept': 'application/json' },
        });
        if (response.ok && !pilotSent) {
          pilotSent = true;
          (window as any).dataLayer = (window as any).dataLayer || [];
          (window as any).dataLayer.push({ event: 'pilot_bewerbung', form_name: 'pilotprogramm' });
        }
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = response.ok ? 'Gesendet \u2714' : 'Pilotplatz anfragen';
        }
        if (response.ok) {
          pilotForm.reset();
          if (successMsg) {
            successMsg.classList.remove('hidden');
          }
        }
      } catch {
        if (submitBtn) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Pilotplatz anfragen';
        }
      }
    });
  }
</script>
