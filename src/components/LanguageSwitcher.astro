---
import { getLangFromUrl, languages } from "../i18n/translations";

const lang = getLangFromUrl(Astro.url);
const otherLang = lang === "de" ? "en" : "de";

// Map current path to equivalent in other language
const pathname = Astro.url.pathname;
let otherPath: string;

if (lang === "de") {
  // DE -> EN
  const deToEn: Record<string, string> = {
    "/": "/en",
    "/ueber-uns": "/en/about",
    "/kontakt": "/en/contact",
    "/impressum": "/en/legal-notice",
    "/datenschutz": "/en/privacy",
    "/koch-app": "/en/cook-app",
    "/produkt": "/en/product",
    "/system": "/en/system",
    "/schulung": "/en/training",
    "/personal": "/en/staff",
    "/pilotprogramm": "/en/pilot-program",
    "/fuer-hotels": "/en/for-hotels",
    "/fuer-restaurants": "/en/for-restaurants",
    "/fuer-sporthotels": "/en/for-sports-hotels",
  };
  otherPath = deToEn[pathname] || `/en${pathname}`;
} else {
  // EN -> DE
  const enToDe: Record<string, string> = {
    "/en": "/",
    "/en/": "/",
    "/en/about": "/ueber-uns",
    "/en/contact": "/kontakt",
    "/en/legal-notice": "/impressum",
    "/en/privacy": "/datenschutz",
    "/en/cook-app": "/koch-app",
    "/en/product": "/produkt",
    "/en/system": "/system",
    "/en/training": "/schulung",
    "/en/staff": "/personal",
    "/en/pilot-program": "/pilotprogramm",
    "/en/for-hotels": "/fuer-hotels",
    "/en/for-restaurants": "/fuer-restaurants",
    "/en/for-sports-hotels": "/fuer-sporthotels",
  };
  otherPath = enToDe[pathname] || pathname.replace(/^\/en/, "");
}
---

<a
  href={otherPath}
  class="text-sm font-medium text-avorix-silver hover:text-avorix-dark transition-colors border border-avorix-light rounded-md px-3 py-1 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2"
>
  {languages[otherLang]}
</a>
