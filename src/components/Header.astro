---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/translations";
import LanguageSwitcher from "./LanguageSwitcher.astro";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const systemLinks = [
  { label: t("nav.system.overview"), href: lang === "de" ? "/system" : "/en/system" },
  { label: t("nav.system.app"), href: lang === "de" ? "/koch-app" : "/en/cook-app" },
  { label: t("nav.system.training"), href: lang === "de" ? "/schulung" : "/en/training" },
  { label: t("nav.system.staff"), href: lang === "de" ? "/personal" : "/en/staff" },
];

const targetLinks = [
  { label: t("nav.target.hotels"), href: lang === "de" ? "/fuer-hotels" : "/en/for-hotels" },
  { label: t("nav.target.restaurants"), href: lang === "de" ? "/fuer-restaurants" : "/en/for-restaurants" },
  { label: t("nav.target.sporthotels"), href: lang === "de" ? "/fuer-sporthotels" : "/en/for-sports-hotels" },
];
---

<header class="fixed top-0 w-full bg-white/95 backdrop-blur-sm border-b border-brand-100 z-50">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href={getLocalizedPath("/", lang)} class="flex items-center gap-3">
      <img src="/logo-dark.jpg" alt="Avorix" class="h-9 rounded" />
      <span class="text-xl font-semibold tracking-tight text-brand-600">AVORIX</span>
    </a>

    <div class="hidden lg:flex items-center gap-6">
      <!-- Unser System Dropdown -->
      <div class="nav-dropdown relative">
        <button type="button" class="nav-dropdown-trigger text-avorix-gray hover:text-avorix-dark transition-colors text-sm font-medium flex items-center gap-1">
          {t("nav.system")}
          <svg class="w-3.5 h-3.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="nav-dropdown-menu hidden absolute top-full left-0 pt-2 min-w-[200px]">
          <div class="bg-white rounded-xl shadow-lg border border-neutral-100 py-2">
            {systemLinks.map(link => (
              <a href={link.href} class="block px-4 py-2 text-sm text-avorix-gray hover:text-avorix-dark hover:bg-neutral-50 transition-colors">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- Für wen Dropdown -->
      <div class="nav-dropdown relative">
        <button type="button" class="nav-dropdown-trigger text-avorix-gray hover:text-avorix-dark transition-colors text-sm font-medium flex items-center gap-1">
          {t("nav.target")}
          <svg class="w-3.5 h-3.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
        </button>
        <div class="nav-dropdown-menu hidden absolute top-full left-0 pt-2 min-w-[220px]">
          <div class="bg-white rounded-xl shadow-lg border border-neutral-100 py-2">
            {targetLinks.map(link => (
              <a href={link.href} class="block px-4 py-2 text-sm text-avorix-gray hover:text-avorix-dark hover:bg-neutral-50 transition-colors">
                {link.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <a href={lang === "de" ? "/pilotprogramm" : "/en/pilot-program"} class="text-avorix-gray hover:text-avorix-dark transition-colors text-sm font-medium">
        {t("nav.pilot")}<sup class="text-brand-500 font-bold text-[0.6rem] ml-0.5">2026</sup>
      </a>

      <a href={lang === "de" ? "/ueber-uns" : "/en/about"} class="text-avorix-gray hover:text-avorix-dark transition-colors text-sm font-medium">
        {t("nav.about")}
      </a>

      <a href={lang === "de" ? "/kontakt" : "/en/contact"} data-cta-location="header" class="bg-brand-500 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-brand-600 transition-colors">
        {t("nav.contact")}
      </a>

      <LanguageSwitcher />
    </div>

    <!-- Mobile menu button -->
    <button id="mobile-menu-btn" class="lg:hidden p-2" aria-label="Menu">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-avorix-light bg-white max-h-[80vh] overflow-y-auto">
    <div class="px-6 py-4 flex flex-col gap-1">
      <!-- Unser System -->
      <div class="py-2">
        <span class="text-xs font-bold text-brand-500 uppercase tracking-wider">{t("nav.system")}</span>
        <div class="mt-1 flex flex-col gap-1 pl-3">
          {systemLinks.map(link => (
            <a href={link.href} class="text-avorix-gray hover:text-avorix-dark text-sm font-medium py-1.5">
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Für wen -->
      <div class="py-2 border-t border-neutral-100">
        <span class="text-xs font-bold text-brand-500 uppercase tracking-wider">{t("nav.target")}</span>
        <div class="mt-1 flex flex-col gap-1 pl-3">
          {targetLinks.map(link => (
            <a href={link.href} class="text-avorix-gray hover:text-avorix-dark text-sm font-medium py-1.5">
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <div class="border-t border-neutral-100 pt-2 flex flex-col gap-2">
        <a href={lang === "de" ? "/pilotprogramm" : "/en/pilot-program"} class="text-avorix-gray hover:text-avorix-dark text-sm font-medium py-1.5">
          {t("nav.pilot")} <sup class="text-brand-500 font-bold text-[0.6rem]">2026</sup>
        </a>
        <a href={lang === "de" ? "/ueber-uns" : "/en/about"} class="text-avorix-gray hover:text-avorix-dark text-sm font-medium py-1.5">
          {t("nav.about")}
        </a>
        <a href={lang === "de" ? "/kontakt" : "/en/contact"} data-cta-location="header" class="bg-brand-500 text-white px-4 py-2 rounded-lg text-sm font-semibold hover:bg-brand-600 transition-colors text-center mt-2">
          {t("nav.contact")}
        </a>
        <div class="mt-2">
          <LanguageSwitcher />
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  // Mobile menu toggle
  const btn = document.getElementById("mobile-menu-btn");
  const menu = document.getElementById("mobile-menu");
  btn?.addEventListener("click", () => {
    menu?.classList.toggle("hidden");
  });

  // Desktop dropdown hover
  document.querySelectorAll(".nav-dropdown").forEach((dropdown) => {
    const trigger = dropdown.querySelector(".nav-dropdown-trigger");
    const menuEl = dropdown.querySelector(".nav-dropdown-menu");
    let timeout: ReturnType<typeof setTimeout>;

    dropdown.addEventListener("mouseenter", () => {
      clearTimeout(timeout);
      menuEl?.classList.remove("hidden");
    });

    dropdown.addEventListener("mouseleave", () => {
      timeout = setTimeout(() => {
        menuEl?.classList.add("hidden");
      }, 150);
    });

    trigger?.addEventListener("click", () => {
      menuEl?.classList.toggle("hidden");
    });
  });
</script>
